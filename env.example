# ============================================================================
#  Projeto Prisma — variáveis de ambiente compartilhadas pela orquestração
#  Copie este arquivo para ".env" antes de subir:   cp .env.example .env
#  O arquivo .env NÃO deve ser versionado (já está no .gitignore).
# ============================================================================

# ---------- PostgreSQL / PostGIS ----------
# Usados por M1, M2, M3, M5, M6, M9 (Postgres) e M4 (PostGIS).
# Cada módulo tem seu PRÓPRIO container de banco; estas credenciais são
# apenas o usuário/senha padrão de cada instância.
PG_USER=prisma
PG_PASSWORD=prisma_secret

# ---------- RabbitMQ ----------
# Use um usuário dedicado (NÃO "guest"): o guest só conecta via localhost,
# e os módulos conectam de outros containers. Ver README › Troubleshooting.
RABBITMQ_USER=prisma
RABBITMQ_PASSWORD=prisma_secret

# ---------- Observações ----------
# MongoDB (M7) e Redis (M8) sobem SEM autenticação no ambiente de
# desenvolvimento, para simplificar a demonstração. Em produção, habilite
# autenticação e troque todas as senhas acima.
